{
  "name": "ehrenamt-justiz-online",
  "version": "0.0.7",
  "type": "module",
  "private": true,
  "license": "MIT",
  "engines": {
    "node": ">=24.11 <25"
  },
  "scripts": {
    "dev": "vite",
    "test": "vitest run",
    "build": "vue-tsc --build --noCheck && vite build && npm run post-build",
    "post-build": "cyclonedx-npm --omit dev --omit optional --output-reproducible -o dist/application.cdx.json",
    "lint": "prettier . --check --cache && eslint . --cache --concurrency auto && vue-tsc --build --noEmit",
    "fix": "prettier . --write --cache && eslint . --fix --cache --concurrency auto"
  },
  "dependencies": {
    "@mdi/font": "7.4.47",
    "@muenchen/muc-patternlab-vue": "7.4.1",
    "@vueuse/core": "13.9.0",
    "moment": "2.30.1",
    "pinia": "3.0.4",
    "vue": "3.5.29",
    "vuetify": "3.12.2",
    "vue-i18n": "11.2.8"
  },
  "devDependencies": {
    "@cyclonedx/cyclonedx-npm": "4.2.0",
    "@intlify/eslint-plugin-vue-i18n": "4.1.1",
    "@intlify/unplugin-vue-i18n": "11.0.7",
    "@muenchen/prettier-codeformat": "1.0.2",
    "@tsconfig/node-lts": "24.0.0",
    "@types/node": "24.10.15",
    "@vitejs/plugin-vue": "6.0.4",
    "@vue/eslint-config-prettier": "10.2.0",
    "@vue/eslint-config-typescript": "14.6.0",
    "@vue/test-utils": "2.4.6",
    "@vue/tsconfig": "0.9.0",
    "eslint": "9.39.3",
    "eslint-plugin-vue": "10.7.0",
    "jsdom": "27.4.0",
    "prettier": "3.8.1",
    "typescript": "5.9.3",
    "unplugin-fonts": "1.4.0",
    "vite": "7.3.1",
    "vite-plugin-vue-devtools": "8.0.7",
    "vite-plugin-vuetify": "2.1.3",
    "vitest": "3.2.4",
    "vue-tsc": "3.2.5"
  }
}
